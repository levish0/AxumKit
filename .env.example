ENVIRONMENT=dev
RUST_LOG=debug

# Stability Layer
STABILITY_CONCURRENCY_LIMIT=500
STABILITY_BUFFER_SIZE=1024
STABILITY_TIMEOUT_SECS=30

# Auth
TOTP_SECRET=
AUTH_SESSION_MAX_LIFETIME_HOURS=720
AUTH_SESSION_SLIDING_TTL_HOURS=168
AUTH_SESSION_REFRESH_THRESHOLD=50
AUTH_EMAIL_VERIFICATION_TOKEN_EXPIRE_TIME=15
AUTH_PASSWORD_RESET_TOKEN_EXPIRE_TIME=15
AUTH_EMAIL_CHANGE_TOKEN_EXPIRE_TIME=15
OAUTH_PENDING_SIGNUP_TTL_MINUTES=10

# Server
HOST=127.0.0.1
PORT=8000

# PostgreSQL / PgDog
POSTGRES_HOST=localhost
POSTGRES_PORT=6432
POSTGRES_DB=axumkit
POSTGRES_NAME=axumkit
POSTGRES_USER=axumkit
POSTGRES_PASSWORD=axumkit_secret
POSTGRES_MAX_CONNECTION=30
POSTGRES_MIN_CONNECTION=5

# Redis
REDIS_SESSION_HOST=localhost
REDIS_SESSION_PORT=6379
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6380
REDIS_CACHE_TTL=3600
REDIS_LOCK_HOST=localhost
REDIS_LOCK_PORT=6381

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/account/oauth/callback/google

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/account/oauth/callback/github

# Cloudflare R2 / S3-compatible storage
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ASSETS_BUCKET_NAME=
R2_ASSETS_PUBLIC_DOMAIN=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# NATS
NATS_URL=nats://localhost:4222

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Image processor
IMAGE_PROCESSOR_URL=http://localhost:6701
IMAGE_PROCESSOR_TIMEOUT_SECS=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Turnstile-Token
CORS_MAX_AGE=86400

# Cookie
COOKIE_DOMAIN=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME=AxumKit

# Frontend & Project
FRONTEND_HOST=http://localhost:5173
PROJECT_NAME=AxumKit
FRONTEND_PATH_VERIFY_EMAIL=/account/verify-email
FRONTEND_PATH_RESET_PASSWORD=/account/reset-password
FRONTEND_PATH_CONFIRM_EMAIL_CHANGE=/account/confirm-email-change

# Cron
CRON_TIMEZONE=UTC
