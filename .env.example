ENVIRONMENT=dev
RUST_LOG=debug

# Stability Layer
STABILITY_CONCURRENCY_LIMIT=500
STABILITY_BUFFER_SIZE=1024
STABILITY_TIMEOUT_SECS=30

# Auth
TOTP_SECRET=
# Key material for deriving the AES-256-GCM key that encrypts TOTP secrets at rest.
# Must be a high-entropy random string and kept out of the database. Changing it makes
# all existing TOTP secrets undecryptable, so rotate only with a migration plan.
TOTP_ENCRYPTION_KEY=
AUTH_SESSION_MAX_LIFETIME_HOURS=720
AUTH_SESSION_SLIDING_TTL_HOURS=168
AUTH_SESSION_REFRESH_THRESHOLD=50
AUTH_EMAIL_VERIFICATION_TOKEN_EXPIRE_TIME=15
AUTH_PASSWORD_RESET_TOKEN_EXPIRE_TIME=15
AUTH_EMAIL_CHANGE_TOKEN_EXPIRE_TIME=15
AUTH_ACCOUNT_DELETION_TOKEN_EXPIRE_TIME=30
AUTH_DEVICE_VERIFY_TOKEN_EXPIRE_TIME=30
OAUTH_PENDING_SIGNUP_TTL_MINUTES=10

# Server
HOST=127.0.0.1
PORT=8000

# PostgreSQL / PgDog. Full URL so the deployment controls the query string
# (`?sslmode=require`, `channel_binding` for managed providers). Native dev
# connects through the local pgdog pooler on 6432.
DATABASE_URL=postgres://axumkit:axumkit_secret@localhost:6432/axumkit
POSTGRES_MAX_CONNECTION=30
POSTGRES_MIN_CONNECTION=5

# Redis
REDIS_SESSION_HOST=localhost
REDIS_SESSION_PORT=6379
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6380
REDIS_CACHE_TTL=3600
REDIS_LOCK_HOST=localhost
REDIS_LOCK_PORT=6381

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/account/oauth/callback/google

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/account/oauth/callback/github

# Cloudflare R2 / S3-compatible storage
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ASSETS_BUCKET_NAME=
R2_ASSETS_PUBLIC_DOMAIN=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# NATS
NATS_URL=nats://localhost:4222

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Media processor
MEDIA_PROCESSOR_URL=http://localhost:6701
MEDIA_PROCESSOR_TIMEOUT_SECS=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Turnstile-Token
CORS_MAX_AGE=86400

# Cookie
COOKIE_DOMAIN=

# Trusted-proxy secret (shared with the SSR/BFF proxy + APISIX gateway). When set, the backend
# trusts X-Real-Client-IP only behind a matching X-Internal-Secret; when empty the header is ignored.
INTERNAL_PROXY_SECRET=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME=AxumKit

# Frontend & Project
FRONTEND_HOST=http://localhost:5173
PROJECT_NAME=AxumKit
FRONTEND_PATH_VERIFY_EMAIL=/account/verify-email
FRONTEND_PATH_RESET_PASSWORD=/account/reset-password
FRONTEND_PATH_CONFIRM_EMAIL_CHANGE=/account/confirm-email-change
FRONTEND_PATH_CONFIRM_ACCOUNT_DELETION=/account/confirm-deletion
FRONTEND_PATH_VERIFY_DEVICE=/account/verify-device

# Cron
CRON_TIMEZONE=UTC
