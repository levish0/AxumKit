# Postgres shared by the postgres container and the app connection.
# Copy this tree to .envs/.local (dev) or .envs/.production and fill real values.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=axumkit
POSTGRES_NAME=axumkit
POSTGRES_USER=axumkit
POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_MAX_CONNECTION=30
# POSTGRES_MIN_CONNECTION=5
