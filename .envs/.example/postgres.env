# Postgres shared by the postgres container and the app connection.
# Copy this tree to .envs/.local (dev) or .envs/.production and fill real values.
#
# DATABASE_URL is the single source of truth the app/worker/migration read. It is a
# full URL so the deployment controls the query string (`?sslmode=require`,
# `channel_binding=require` for managed providers); with the bundled pgdog pooler
# point it at pgdog:6432 instead of postgres:5432.
DATABASE_URL=postgres://axumkit:CHANGE_ME@postgres:5432/axumkit

# Consumed by:
#   1. the postgres CONTAINER (initdb)
#   2. the infra healthcheck — pg_isready -U $POSTGRES_USER
POSTGRES_DB=axumkit
POSTGRES_USER=axumkit
POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_MAX_CONNECTION=30
# POSTGRES_MIN_CONNECTION=5
