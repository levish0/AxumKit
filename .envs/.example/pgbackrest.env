# pgBackRest repo on R2 (S3-compatible) — a DEDICATED backup bucket, separate from the
# asset bucket in r2.env. Loaded by the postgres container for WAL archiving
# (archive_command) and read by every `pgbackrest ... backup` command.
#
# pgBackRest maps each option to a PGBACKREST_<OPTION> env var; the static options live
# in compose/production/pgbackrest/pgbackrest.conf, the per-env + secret ones are here.
#
# Isolate prod and dev: either use a different bucket per env, or one bucket with a
# different REPO1_PATH prefix per env (.production -> /production, .dev -> /dev).
PGBACKREST_REPO1_S3_BUCKET=CHANGE_ME
# Host only, NO scheme — e.g. <account_id>.r2.cloudflarestorage.com
PGBACKREST_REPO1_S3_ENDPOINT=CHANGE_ME
PGBACKREST_REPO1_S3_REGION=auto
PGBACKREST_REPO1_S3_KEY=CHANGE_ME
PGBACKREST_REPO1_S3_KEY_SECRET=CHANGE_ME
PGBACKREST_REPO1_PATH=/
