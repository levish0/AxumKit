ENVIRONMENT=dev
RUST_LOG=info

HOST=0.0.0.0
PORT=8000

TOTP_SECRET=CHANGE_ME
AUTH_SESSION_MAX_LIFETIME_HOURS=720
AUTH_SESSION_SLIDING_TTL_HOURS=168
