# Chef stage - install cargo-chef
FROM rust:1.97.1 AS chef
WORKDIR /app
RUN cargo install cargo-chef

# Planner stage - generate recipe.json
FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

# Builder stage - build dependencies then application in debug mode
FROM chef AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --recipe-path recipe.json

COPY . .
RUN cargo build -p server -p worker -p migration

# Runtime stage for server
FROM debian:stable-slim AS server-runtime

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r app && useradd -r -g app app
WORKDIR /app

COPY --from=builder /app/target/debug/server .
COPY --from=builder /app/target/debug/migration .

RUN chown -R app:app /app
USER app

EXPOSE 8000
CMD ["./server"]

# Runtime stage for worker
FROM debian:stable-slim AS worker-runtime

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r app && useradd -r -g app app
WORKDIR /app

COPY --from=builder /app/target/debug/worker .

RUN chown -R app:app /app
USER app

CMD ["./worker"]
