# Compose variables for the DEV deployment. NOT secrets — committed.
# Real secrets live in ../.envs/.dev/ (gitignored).
#
# Usage (from deploy/):
#   docker compose --env-file dev.env -f docker-compose.infra.yml -f docker-compose.app.yml up -d
DEPLOY_ENV=dev
COMPOSE_PROJECT_NAME=axumkit_dev
# GHCR image tag for the axumkit server/migration/worker images.
APP_VERSION=0.10.3
# Host port (localhost-only) the tunnel/ingress points at — APISIX.
APISIX_HOST_PORT=9080
# Postgres on 127.0.0.1 only (loopback) for a DB client over an SSH tunnel.
POSTGRES_HOST_PORT=15434
