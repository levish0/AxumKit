# Compose variables for the PRODUCTION deployment. NOT secrets — committed.
# Real secrets live in ../.envs/.production/ (gitignored).
#
# Usage (from deploy/):
#   docker compose --env-file production.env -f docker-compose.infra.yml -f docker-compose.app.yml up -d
DEPLOY_ENV=production
COMPOSE_PROJECT_NAME=axumkit_production
# GHCR image tag. Pin a released version; promote here after testing on dev.
APP_VERSION=0.10.3
# Host port (localhost-only) the tunnel/ingress points at — APISIX.
# Different from dev so both can run on one host.
APISIX_HOST_PORT=9090
# Postgres on 127.0.0.1 only (loopback) for a DB client over an SSH tunnel.
POSTGRES_HOST_PORT=15435
